{
  "cli": {
    "version": ">= 16.31.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "testflight": {
      "developmentClient": false,
      "distribution": "internal",
      "ios": {
        "buildConfiguration": "Release"
      }
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "ios": {
        "companyName": "Klack LLC"
      }
    },
    "testflight": {
      "ios": {
        "companyName": "Klack LLC"
      }
    }
  }
}